---
import { getCollection } from "astro:content";
import BlogPagesLayout from '../../layouts/BlogPagesLayout.astro';
const posts = await getCollection("blog");
---
<BlogPagesLayout>
  <h1>Blog</h1>

<ul>
  {posts.map(post => (
    <li>
      <a href={`/blog/${post.slug}`}>
        {post.data.title}
      </a>
    </li>
  ))}
</ul>
</BlogPagesLayout>