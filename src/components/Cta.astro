---
import { Icon } from "astro-icon/components";
import Button from "../ui/Button.astro";
---

<section class="cta">
  <div class="inner-cta">
    <h2 class="title-cta">¿Listo para dar el siguiente paso?</h2>

    <p class="cta-text">
      Estamos listos para transformar tu presencia digital. Escríbenos y
      empecemos a construir algo increíble hoy mismo.
    </p>

    <Button
      label="Hablemos por WhatsApp"
      href="https://wa.me/18293964841?text=Vengo%20desde%20Dualsym"
      target="_blank"
    >
      <Icon slot="icon" name="mdi:whatsapp" size="18" />
    </Button>
  </div>
</section>

<style>
.cta {
  padding: 4rem 1.5rem;

}

.inner-cta {
   max-width:960px;
    margin: 0 auto;

    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.25rem;
}



</style>
